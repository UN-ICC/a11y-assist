{
  "name": "apg-query",
  "version": "0.1.0",
  "description": "Programmatic access to the W3C ARIA Authoring Practices Guide (APG) patterns. Analogous to aria-query, but for APG.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src/data/*.json"
  ],
  "scripts": {
    "build": "tsc && mkdir -p dist/data && cp src/data/*.json dist/data/",
    "typecheck": "tsc --noEmit",
    "extract": "tsx tools/extract.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "cheerio": "^1.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT",
  "keywords": ["accessibility", "a11y", "aria", "apg", "wai-aria", "authoring-practices"]
}
