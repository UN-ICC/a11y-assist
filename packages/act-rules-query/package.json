{
  "name": "act-rules-query",
  "version": "0.1.0",
  "description": "Programmatic access to W3C Accessibility Conformance Testing (ACT) Rules. Loaded from snapshotted YAML/Markdown source files.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src/data/*.json"
  ],
  "scripts": {
    "build": "tsc && mkdir -p dist/data && cp src/data/*.json dist/data/",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "test:types": "tsc -p test",
    "load": "tsx tools/load-yaml.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "gray-matter": "^4.0.3",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT",
  "keywords": ["accessibility", "a11y", "act", "act-rules", "wcag", "conformance"]
}
