{
  "name": "wcag-query",
  "version": "0.1.0",
  "description": "Programmatic access to WCAG 2.2 Success Criteria, Techniques, and Failures.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src/data/*.json"
  ],
  "scripts": {
    "build": "tsc && mkdir -p dist/data && cp src/data/*.json dist/data/",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "test:types": "tsc -p test",
    "extract": "tsx tools/extract.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "cheerio": "^1.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT",
  "keywords": [
    "accessibility",
    "a11y",
    "wcag",
    "wcag22",
    "success-criteria"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UN-ICC/a11y-assist.git",
    "directory": "packages/wcag-query"
  },
  "homepage": "https://github.com/UN-ICC/a11y-assist#readme",
  "bugs": "https://github.com/UN-ICC/a11y-assist/issues"
}
